# Faculty Products Org OS — environment variables
# Copy to .env and fill in. The .env file is gitignored — don't commit it.

# Slack — bot token + workspace ID
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T...

# GitHub — personal access token with repo + read:org scopes
# Get from: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Linear — personal API key
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Snowflake — account + read-only credentials
# Get from: your data team (@priya)
SNOWFLAKE_ACCOUNT=...
SNOWFLAKE_USER=...
SNOWFLAKE_PRIVATE_KEY=...

# Google Drive — OAuth credentials JSON (path to file)
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_OAUTH_CREDENTIALS=/absolute/path/to/credentials.json
